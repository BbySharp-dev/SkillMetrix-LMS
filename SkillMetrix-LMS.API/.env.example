# =============================
# SkillMetrix-LMS.API env example
# =============================

# Database
ConnectionStrings__DefaultConnection=Server=localhost,1434;Database=SkillMetrixLMS;User Id=sa;Password=YourStrong@Passw0rd;TrustServerCertificate=True;

# JWT
Jwt__SecretKey=SkillMetrixLMS-super-secret-key-for-development-only-min-32-chars!
Jwt__Issuer=SkillMetrixLMS
Jwt__Audience=SkillMetrixLMS
Jwt__AccessTokenExpirationMinutes=15
Jwt__RefreshTokenExpirationDays=7

# CORS
Cors__AllowedOrigins__0=http://localhost:5173

# Cloudinary (optional)
Cloudinary__CloudName=your_cloud_name
Cloudinary__ApiKey=your_api_key
Cloudinary__ApiSecret=your_api_secret
